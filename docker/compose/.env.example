# Vulis platform stack — environment template
#
# Copy to .env (next to docker-compose.platform.yml) and edit.
# DO NOT commit your real .env.
#
# These values are consumed by:
#   - docker/compose/docker-compose.platform.yml (compose interpolation)
#   - the platform services via the VULIS_* env vars

# ─── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=vulis
POSTGRES_PASSWORD=vulis-dev-password
POSTGRES_DB=vulis
POSTGRES_HOST_PORT=5432

# ─── Redis ──────────────────────────────────────────────────────
REDIS_HOST_PORT=6379

# ─── Mosquitto (MQTT 5) ────────────────────────────────────────
MQTT_USER=vulis
MQTT_PASSWORD=vulis-dev-password
MQTT_HOST_PORT=1883
MQTT_WS_HOST_PORT=9001

# ─── Keycloak ───────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_HOST_PORT=8080
KEYCLOAK_REALM=vulis
# Confidential client secret for `vulis-cli` (M1.8)
KEYCLOAK_CLIENT_VULIS_CLI_SECRET=vulis-cli-secret-change-me

# ─── Traefik ────────────────────────────────────────────────────
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8081

# ─── Vulis settings (consumed by services when they boot) ──────
VULIS_SURFACE=server
VULIS_ENVIRONMENT=dev
VULIS_POSTGRES_DSN=postgresql://vulis:vulis-dev-password@postgres:5432/vulis
VULIS_REDIS_URL=redis://redis:6379/0
VULIS_MQTT_HOST=mosquitto
VULIS_MQTT_PORT=1883
VULIS_MQTT_USERNAME=vulis
VULIS_MQTT_PASSWORD=vulis-dev-password
VULIS_KEYCLOAK_URL=http://keycloak:8080
VULIS_KEYCLOAK_REALM=vulis
# Storage backend — for the platform stack, default to local-fs (no SMB
# in compose). Point VULIS_STORAGE_SMB_* at a real share to test SMB.
VULIS_STORAGE_BACKEND=local-fs
VULIS_STORAGE_LOCAL_ROOT=/data/vulis
VULIS_OTEL_ENDPOINT=
