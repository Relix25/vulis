{
  "realm": "vulis",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 1800,
  "roles": {
    "realm": [
      { "name": "admin",         "description": "Full access to the platform" },
      { "name": "data-scientist","description": "Can create projects, datasets, models" },
      { "name": "annotator",     "description": "Read-only on projects, can annotate" },
      { "name": "operator",      "description": "Can transition tasks to deployed" },
      { "name": "reviewer",      "description": "Can approve/reject model versions" }
    ]
  },
  "groups": [
    {
      "name": "tenants",
      "path": "/tenants",
      "subGroups": [
        {
          "name": "default",
          "path": "/tenants/default",
          "realmRoles": ["admin", "data-scientist", "annotator", "operator", "reviewer"]
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@vulis.local",
      "firstName": "Platform",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "admin", "temporary": false }
      ],
      "realmRoles": ["admin"],
      "groups": ["/tenants/default"]
    },
    {
      "username": "data-scientist",
      "email": "data-scientist@vulis.local",
      "firstName": "Data",
      "lastName": "Scientist",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "data-scientist", "temporary": false }
      ],
      "realmRoles": ["data-scientist"],
      "groups": ["/tenants/default"]
    },
    {
      "username": "annotator",
      "email": "annotator@vulis.local",
      "firstName": "Data",
      "lastName": "Annotator",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "annotator", "temporary": false }
      ],
      "realmRoles": ["annotator"],
      "groups": ["/tenants/default"]
    },
    {
      "username": "operator",
      "email": "operator@vulis.local",
      "firstName": "Floor",
      "lastName": "Operator",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "operator", "temporary": false }
      ],
      "realmRoles": ["operator"],
      "groups": ["/tenants/default"]
    },
    {
      "username": "reviewer",
      "email": "reviewer@vulis.local",
      "firstName": "Model",
      "lastName": "Reviewer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "reviewer", "temporary": false }
      ],
      "realmRoles": ["reviewer"],
      "groups": ["/tenants/default"]
    }
  ],
  "clients": [
    {
      "clientId": "vulis-web",
      "name": "Vulis Web (React)",
      "description": "Public OIDC client for the Vulis webapp (PKCE)",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "vulis-tauri",
      "name": "Vulis Tauri App",
      "description": "Public OIDC client for the Vulis Tauri workstation app (PKCE)",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:1420/*",
        "tauri://localhost/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "vulis-cli",
      "name": "Vulis CLI",
      "description": "Confidential OIDC client for machine-to-machine (vulis CLI, M1.8)",
      "publicClient": false,
      "secret": "vulis-cli-secret-change-me",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "attributes": {}
    }
  ]
}
