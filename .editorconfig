# EditorConfig — https://editorconfig.org
# Vulis monorepo conventions

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
# Markdown: preserve trailing whitespace (two trailing spaces = line break)
trim_trailing_whitespace = false
max_line_length = off

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc,json5}]
indent_size = 2

[*.{js,cjs,mjs,jsx,ts,cts,mts,tsx,vue,svelte,astro,css,scss,less,html}]
indent_size = 2

[*.{toml}]
indent_size = 2

[*.{go}]
indent_style = tab

[*.{rs}]
indent_size = 4
max_line_length = 100

[*.{proto,protoc}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{bat,cmd,ps1}]
end_of_line = crlf
